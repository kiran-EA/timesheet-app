{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    { "src": "/auth(.*)",      "dest": "api/index.py" },
    { "src": "/jira(.*)",      "dest": "api/index.py" },
    { "src": "/timesheet(.*)", "dest": "api/index.py" },
    { "src": "/calendar(.*)",  "dest": "api/index.py" },
    { "src": "/health",        "dest": "api/index.py" },
    { "src": "/(.*)",          "dest": "frontend" }
  ]
}
